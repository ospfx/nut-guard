#!/bin/sh /etc/rc.common
# Nut Guard — UPS monitoring daemon (procd)

USE_PROCD=1
START=99
STOP=10

PROG=/usr/share/nut-guard/daemon.js

start_service() {
	procd_open_instance
	procd_set_param command /usr/bin/node "$PROG"
	procd_set_param respawn ${respawn_threshold:-3600} ${respawn_timeout:-5} ${respawn_retry:-5}
	procd_set_param stdout 1
	procd_set_param stderr 1
	procd_set_param pidfile /var/run/nut-guard.pid
	procd_close_instance
}

service_triggers() {
	procd_add_reload_trigger nut-guard
}
