{
	"luci-app-nut-guard": {
		"description": "Grant UCI and ubus access for luci-app-nut-guard",
		"read": {
			"uci": [ "nut-guard" ],
			"ubus": {
				"nutguard": [ "get_config", "get_ups" ],
				"luci": [ "getInitList", "getInitStatus" ]
			}
		},
		"write": {
			"uci": [ "nut-guard" ],
			"ubus": {
				"nutguard": [ "set_config" ],
				"luci": [ "setInitAction" ]
			}
		}
	}
}
