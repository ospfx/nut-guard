#!/bin/sh /etc/rc.common
# nut-guard init script - NUT UPS monitor
# Copyright (C) 2025 ospfx

USE_PROCD=1
START=99
STOP=10

PROG=/usr/libexec/nut-guard/core.lua

start_service() {
	local enabled
	config_load "nut_guard"
	config_get_bool enabled main enabled 0
	[ "$enabled" = "0" ] && {
		logger -t nut-guard "Service is disabled in UCI config"
		return 0
	}

	local ups ip timeout
	config_get ups     main ups                    "myups"
	config_get ip      main ip                     "127.0.0.1"
	config_get timeout main command_timeout_seconds "3"

	logger -t nut-guard "Starting: UPS=${ups} host=${ip} timeout=${timeout}s"

	# Verify connectivity once at startup; log result
	local out
	out=$(lua "$PROG" "$ups" "$ip" "$timeout" 2>&1) && \
		logger -t nut-guard "NUT connectivity OK" || \
		logger -t nut-guard "NUT connectivity check failed: $out"
}

stop_service() {
	logger -t nut-guard "Stopped"
}

reload_service() {
	logger -t nut-guard "Reloading configuration"
	start_service
}

service_triggers() {
	procd_add_reload_trigger "nut_guard"
}
